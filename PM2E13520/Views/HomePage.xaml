<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PM2E13520.Views.HomePage"
             Title="Agregar Sitio"
             BackgroundColor="#F0F4F0">

    <Shell.TitleView>
        <Label Text="📍 Registrar Sitio"
               TextColor="Black"
               FontSize="18"
               FontAttributes="Bold"
               VerticalOptions="Center" />
    </Shell.TitleView>

    <ScrollView>
        <VerticalStackLayout Padding="20,16" Spacing="14" MaximumWidthRequest="480">

            <!-- Título visible en página -->
            <Label Text="Nuevo Sitio"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="#1B5E20"
                   HorizontalOptions="Start"
                   Margin="4,0,0,0" />
           

            <!-- Imagen del sitio -->
            <Border StrokeThickness="0"
                    StrokeShape="RoundRectangle 20"
                    HeightRequest="210"
                    BackgroundColor="#E0EDE0"
                    HorizontalOptions="Fill">
                <Grid>
                    <Image x:Name="ImgSitio" Aspect="AspectFill" />
                    <!-- Placeholder -->
                    <VerticalStackLayout x:Name="ImgPlaceholder"
                                         VerticalOptions="Center"
                                         HorizontalOptions="Center"
                                         Spacing="8">
                        <Border StrokeThickness="0"
                                StrokeShape="RoundRectangle 40"
                                BackgroundColor="#C8DFC8"
                                HeightRequest="72"
                                WidthRequest="72"
                                HorizontalOptions="Center">
                            <Label Text="📸"
                                   FontSize="34"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                        <Label Text="Sin foto"
                               FontSize="13"
                               TextColor="#7A9A7A"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- Botón cámara -->
            <Border StrokeThickness="0"
                    StrokeShape="RoundRectangle 12"
                    BackgroundColor="#2E7D32"
                    HeightRequest="48"
                    HorizontalOptions="Fill">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTomarFotoClicked" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       Spacing="10">
                    <Label Text="📷" FontSize="20" VerticalOptions="Center" />
                    <Label Text="Tomar Foto"
                           TextColor="White"
                           FontSize="15"
                           FontAttributes="Bold"
                           VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Border>

            <!-- Coordenadas GPS -->
            <Border StrokeThickness="0"
                    StrokeShape="RoundRectangle 14"
                    BackgroundColor="White"
                    Padding="16,14"
                    HorizontalOptions="Fill">
                <VerticalStackLayout Spacing="10">
                    <HorizontalStackLayout Spacing="6">
                        <Label Text="📡" FontSize="14" VerticalOptions="Center" />
                        <Label Text="Coordenadas GPS"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="#1B5E20"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                        <Border Grid.Column="0"
                                StrokeThickness="1"
                                Stroke="#C8E6C9"
                                StrokeShape="RoundRectangle 8"
                                Padding="10,6">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Latitud"
                                       FontSize="10"
                                       TextColor="#7A9A7A" />
                                <Entry x:Name="EntLatitud"
                                       Placeholder="0.00000"
                                       IsReadOnly="True"
                                       FontSize="13"
                                       PlaceholderColor="#C8D8C8" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="1"
                                StrokeThickness="1"
                                Stroke="#C8E6C9"
                                StrokeShape="RoundRectangle 8"
                                Padding="10,6">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Longitud"
                                       FontSize="10"
                                       TextColor="#7A9A7A" />
                                <Entry x:Name="EntLongitud"
                                       Placeholder="0.00000"
                                       IsReadOnly="True"
                                       FontSize="13"
                                       PlaceholderColor="#C8D8C8" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Descripción -->
            <Border StrokeThickness="0"
                    StrokeShape="RoundRectangle 14"
                    BackgroundColor="White"
                    Padding="16,14"
                    HorizontalOptions="Fill">
                <VerticalStackLayout Spacing="10">
                    <HorizontalStackLayout Spacing="6">
                        <Label Text="✏️" FontSize="14" VerticalOptions="Center" />
                        <Label Text="Descripción"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="#1B5E20"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    <Border StrokeThickness="1"
                            Stroke="#C8E6C9"
                            StrokeShape="RoundRectangle 8"
                            Padding="10,6">
                        <Entry x:Name="EntDescripcion"
                               Placeholder="Describe tu lugar..."
                               MaxLength="100"
                               FontSize="14"
                               PlaceholderColor="#A8C4A8" />
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- Botón Guardar -->
            <Border StrokeThickness="0"
                    StrokeShape="RoundRectangle 14"
                    BackgroundColor="#FF8F00"
                    HeightRequest="54"
                    HorizontalOptions="Fill"
                    Margin="0,6,0,28">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnGuardarClicked" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       Spacing="10">
                    <Label Text="💾" FontSize="22" VerticalOptions="Center" />
                    <Label Text="Guardar Sitio"
                           TextColor="White"
                           FontSize="16"
                           FontAttributes="Bold"
                           VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>