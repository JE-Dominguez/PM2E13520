<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:PM2E13520.Converters"
             x:Class="PM2E13520.Views.ListPage"
             Title="Mis Sitios">

    <ContentPage.Resources>
        <conv:Base64ToImageConverter x:Key="Base64ToImage" />
    </ContentPage.Resources>

    <Grid RowDefinitions="*, Auto">

        <CollectionView x:Name="ListaSitios"
                        Grid.Row="0"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="10,8" Padding="0" CornerRadius="14" HasShadow="True">

                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnVerMapaClicked" />
                        </Frame.GestureRecognizers>

                        <Grid RowDefinitions="200, Auto, Auto, Auto" RowSpacing="4">

                            <!-- Imagen arriba, ancho completo -->
                            <Image Grid.Row="0"
                                   Source="{Binding Imagen, Converter={StaticResource Base64ToImage}}"
                                   Aspect="AspectFill"
                                   HeightRequest="200" />

                            <!-- Botones flotantes sobre la imagen, esquina superior derecha -->
                            <HorizontalStackLayout Grid.Row="0"
                                                    HorizontalOptions="End"
                                                    VerticalOptions="Start"
                                                    Margin="0,10,10,0"
                                                    Spacing="8">

                                <!-- Compartir -->
                                <Border StrokeThickness="0"
                                        StrokeShape="RoundRectangle 19"
                                        BackgroundColor="#FFFFFF"
                                        HeightRequest="38"
                                        WidthRequest="38">
                                    <Button Text="📤"
                                            CommandParameter="{Binding .}"
                                            Clicked="OnCompartirClicked"
                                            FontSize="16"
                                            BackgroundColor="Transparent"
                                            HeightRequest="38"
                                            WidthRequest="38"
                                            Padding="0" />
                                </Border>

                                <!-- Eliminar -->
                                <Border StrokeThickness="0"
                                        StrokeShape="RoundRectangle 19"
                                        BackgroundColor="#FFFFFF"
                                        HeightRequest="38"
                                        WidthRequest="38">
                                    <Button Text="🗑️"
                                            CommandParameter="{Binding .}"
                                            Clicked="OnEliminarClicked"
                                            FontSize="16"
                                            BackgroundColor="Transparent"
                                            HeightRequest="38"
                                            WidthRequest="38"
                                            Padding="0" />
                                </Border>

                            </HorizontalStackLayout>

                            <!-- Descripción -->
                            <Label Grid.Row="1"
                                   Text="{Binding Descripcion}"
                                   FontAttributes="Bold"
                                   FontSize="16"
                                   Margin="14,8,14,0" />

                            <!-- Latitud -->
                            <Label Grid.Row="2"
                                   Text="{Binding Latitud, StringFormat='Lat: {0:F5}'}"
                                   FontSize="13"
                                   TextColor="Gray"
                                   Margin="14,0,14,0" />

                            <!-- Longitud -->
                            <Label Grid.Row="3"
                                   Text="{Binding Longitud, StringFormat='Lon: {0:F5}'}"
                                   FontSize="13"
                                   TextColor="Gray"
                                   Margin="14,0,14,10" />

                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>